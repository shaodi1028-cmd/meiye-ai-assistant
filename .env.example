# 基础服务配置
NODE_ENV=development
HOST=127.0.0.1
PORT=4173

# 默认使用 data/db.json。部署时建议改成挂载磁盘路径，例如 /data/db.json。
MEIYE_STORE=json
MEIYE_DB_PATH=data/db.json
MEIYE_DB_SEED_PATH=data/db.json
MEIYE_BACKUP_DIR=data/backups
MEIYE_MAX_BACKUPS=10

# MySQL 数据层。把 MEIYE_STORE 改成 mysql 后生效。
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=meiye_ai
MYSQL_USER=meiye_user
MYSQL_PASSWORD=meiye_password
MYSQL_STATE_TABLE=meiye_app_state
MYSQL_BACKUP_TABLE=meiye_backups

# 任选一个服务商配置即可。都不配置时，系统使用本地美业垂直模板。

# OpenRouter 有免费模型路由，可用于快速测试。
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-3n-e4b-it:free

# Gemini API 有免费层，可用于文本生成测试。
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq 有 Free Plan 限额，可用于高速文本生成测试。
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
